<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <script>
  if (sessionStorage.getItem('auth') !== 'yes') {
    window.location.href = '?page=login';
  }
</script>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: 'Google Sans', Roboto, Arial, sans-serif; background: #f8f9fa; color: #202124; padding: 30px; min-height: 100vh; }
      .container { max-width: 900px; margin: 0 auto; }
      h1 { font-size: 24px; font-weight: 500; color: #1a73e8; margin-bottom: 6px; }
      .subtitle { color: #5f6368; margin-bottom: 24px; font-size: 14px; }
      .cards { display: flex; gap: 16px; margin-bottom: 28px; flex-wrap: wrap; }
      .card { flex: 1; min-width: 140px; background: white; border-radius: 14px; padding: 20px; text-align: center; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
      .card .num { font-size: 32px; font-weight: 500; color: #1a73e8; }
      .card .lbl { font-size: 13px; color: #5f6368; margin-top: 2px; }
      .block { background: white; border-radius: 14px; padding: 24px; margin-bottom: 20px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
      .block h2 { font-size: 16px; margin-bottom: 16px; }
      table { width: 100%; border-collapse: collapse; }
      th { background: #f1f3f4; padding: 10px 14px; text-align: left; font-size: 12px; color: #5f6368; }
      td { padding: 10px 14px; font-size: 14px; border-bottom: 1px solid #f1f3f4; }
      .empty { text-align: center; padding: 40px; color: #80868b; }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>📊 Аналитика брака шин</h1>
      <p class="subtitle">Статистика по причинам и годам</p>
      <div class="cards" id="cards"></div>
      <div class="block"><h2>📋 По причинам брака</h2><div id="reasonsTable"></div></div>
      <div class="block"><h2>📅 По годам производства</h2><div id="yearsTable"></div></div>
    </div>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        google.script.run.withSuccessHandler(function(d) {
          document.getElementById('cards').innerHTML = 
            '<div class="card"><div class="num">'+d.totalRecords+'</div><div class="lbl">Всего записей</div></div>'+
            '<div class="card"><div class="num">'+d.totalQuantity+'</div><div class="lbl">Всего шин</div></div>'+
            '<div class="card"><div class="num">'+d.reasons.length+'</div><div class="lbl">Причин</div></div>';
          
          var rh = '<table><thead><tr><th>Причина</th><th>Записей</th><th>Штук</th></tr></thead><tbody>';
          d.reasons.forEach(function(r) { rh += '<tr><td>'+r.name+'</td><td>'+r.count+'</td><td>'+r.quantity+'</td></tr>'; });
          rh += '</tbody></table>';
          document.getElementById('reasonsTable').innerHTML = d.reasons.length ? rh : '<p class="empty">Нет данных</p>';
          
          var yh = '<table><thead><tr><th>Год</th><th>Записей</th><th>Штук</th></tr></thead><tbody>';
          d.years.forEach(function(y) { yh += '<tr><td>'+y.name+'</td><td>'+y.count+'</td><td>'+y.quantity+'</td></tr>'; });
          yh += '</tbody></table>';
          document.getElementById('yearsTable').innerHTML = d.years.length ? yh : '<p class="empty">Нет данных</p>';
        }).getTireAnalytics();
      });
    </script>
  </body>
</html>
