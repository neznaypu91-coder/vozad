<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: 'Google Sans', Roboto, sans-serif; background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 100%); color: #202124; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
      .login-box { background: white; border-radius: 20px; padding: 48px 40px; box-shadow: 0 8px 30px rgba(0,0,0,0.1); text-align: center; width: 380px; }
      .login-box .icon { font-size: 56px; margin-bottom: 16px; }
      .login-box h1 { font-size: 22px; font-weight: 500; color: #1a73e8; margin-bottom: 8px; }
      .login-box p { color: #5f6368; font-size: 14px; margin-bottom: 28px; }
      .login-box input { width: 100%; padding: 16px; border: 2px solid #e0e0e0; border-radius: 12px; font-size: 18px; text-align: center; font-family: inherit; letter-spacing: 4px; }
      .login-box input:focus { outline: none; border-color: #1a73e8; }
      .login-box button { width: 100%; padding: 16px; margin-top: 16px; background: #1a73e8; color: white; border: none; border-radius: 12px; font-size: 16px; font-weight: 500; cursor: pointer; font-family: inherit; }
      .login-box button:hover { background: #1765cc; }
      .login-box button:disabled { background: #a8c7fa; cursor: not-allowed; }
      .meme-img { width: 200px; height: 200px; object-fit: contain; margin: 16px auto; display: block; }
      .btn-link { display: inline-block; margin-top: 12px; padding: 14px 28px; background: #1a73e8; color: white; border-radius: 12px; text-decoration: none; font-size: 15px; font-weight: 500; }
      .btn-link:hover { background: #1765cc; }
    </style>
  </head>
  <body>
    <div class="login-box" id="loginBox">
      <div class="icon">🔐</div>
      <h1>Доступ к системе</h1>
      <p id="loginText">Введите пароль для входа</p>
      <input type="password" id="password" placeholder="••••" maxlength="20" onkeydown="if(event.key==='Enter')checkPwd()">
      <button onclick="checkPwd()">Войти</button>
    </div>
    
    <script>
      function checkPwd() {
        var pwd = document.getElementById('password').value.trim();
        if (!pwd) return;
        
        var btn = document.querySelector('button');
        btn.disabled = true; btn.textContent = '...';
        
        google.script.run
          .withSuccessHandler(function(ok) {
            if (ok) {
              sessionStorage.setItem('auth', 'yes');
              document.getElementById('loginBox').innerHTML = 
                '<div class="icon">🎉</div>' +
                '<h1>Пароль верный!</h1>' +
                '<img class="meme-img" src="https://media.giphy.com/media/26u4lOMA8JKSnL9Uk/giphy.gif" alt="успех">' +
                '<a href="?" class="btn-link">📊 На работу</a>';
            } else {
              document.getElementById('loginBox').innerHTML = 
                '<div class="icon">😢</div>' +
                '<h1>Неверный пароль</h1>' +
                '<img class="meme-img" src="https://media.giphy.com/media/l4FGI8GoTL7N4DsyI/giphy.gif" alt="грусть">' +
                '<button onclick="location.reload()" style="width:100%;padding:16px;margin-top:16px;background:#1a73e8;color:white;border:none;border-radius:12px;font-size:16px;font-weight:500;cursor:pointer;font-family:inherit;">🔄 Попробовать снова</button>';
            }
          })
          .checkPassword(pwd);
      }
    </script>
  </body>
</html>
