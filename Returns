<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <script>
  if (sessionStorage.getItem('auth') !== 'yes') {
    window.location.href = '?page=login';
  }
</script>
    <link href="https://cdn.jsdelivr.net/npm/@mdi/font@6.9.96/css/materialdesignicons.min.css" rel="stylesheet">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Google Sans', Roboto, sans-serif;
        background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 100%);
        color: #202124; padding: 30px; min-height: 100vh;
      }
      .container { max-width: 900px; margin: 0 auto; }
      h1 { font-size: 28px; font-weight: 500; color: #1a73e8; margin-bottom: 6px; text-align: center; }
      .subtitle { font-size: 14px; color: #5f6368; margin-bottom: 28px; text-align: center; }
      
      .date-row {
        display: flex; justify-content: center; margin-bottom: 28px;
      }
      .date-row input {
        padding: 16px 24px; border: 2px solid #e0e0e0; border-radius: 14px;
        font-size: 18px; font-family: inherit; text-align: center;
        background: white; box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        transition: border-color 0.2s, box-shadow 0.2s;
      }
      .date-row input:focus {
        outline: none; border-color: #1a73e8;
        box-shadow: 0 0 0 4px rgba(26,115,232,0.1);
      }
      
      .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px; }
      @media (max-width: 650px) { .grid { grid-template-columns: 1fr; } }
      
      .block {
        background: white; border-radius: 16px; padding: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border-top: 5px solid #1a73e8;
        transition: transform 0.15s, box-shadow 0.15s;
      }
      .block:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.1); }
      .block.mp { border-top-color: #ea4335; }
      .block h2 { font-size: 16px; font-weight: 500; margin-bottom: 4px; display: flex; align-items: center; gap: 8px; }
      .block .desc { font-size: 12px; color: #5f6368; margin-bottom: 18px; }
      .block label { font-size: 12px; font-weight: 500; color: #5f6368; display: block; margin-bottom: 4px; }
      .block input {
        width: 100%; padding: 14px 16px; border: 2px solid #e8eaed; border-radius: 10px;
        font-size: 17px; font-family: inherit; margin-bottom: 8px;
        background: #fafafa; transition: all 0.2s;
      }
      .block input:focus {
        outline: none; border-color: #1a73e8; background: white;
        box-shadow: 0 0 0 3px rgba(26,115,232,0.08);
      }
      .block .row { display: flex; gap: 12px; }
      .block .row > div { flex: 1; }
      .block .icon-label { display: flex; align-items: center; gap: 6px; margin-bottom: 6px; }
      .block .icon-label span { font-size: 18px; }
      
      button {
        width: 100%; padding: 20px; background: linear-gradient(135deg, #1a73e8, #1557b0);
        color: white; border: none; border-radius: 16px; font-size: 18px;
        font-weight: 500; cursor: pointer; font-family: inherit;
        box-shadow: 0 4px 14px rgba(26,115,232,0.3);
        transition: all 0.2s;
      }
      button:hover { box-shadow: 0 6px 20px rgba(26,115,232,0.4); transform: translateY(-1px); }
      button:disabled { background: #a8c7fa; box-shadow: none; cursor: not-allowed; transform: none; }
      
      .result-message {
        margin-top: 20px; padding: 18px; border-radius: 12px;
        font-size: 15px; text-align: center; display: none;
      }
      .success { background: #e6f4ea; color: #1e8e3e; display: block; border: 1px solid #ceead6; }
      .error { background: #fce8e6; color: #d93025; display: block; border: 1px solid #f5c6cb; }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>📦 Возвраты</h1>
      <p class="subtitle">Укажите дату и заполните количество по каждой операции</p>
      
      <div id="messageBox" class="result-message"></div>
      
      <div class="date-row">
        <input type="date" id="reportDate">
      </div>
      
      <div class="grid">
        <!-- ОПТ Приемка -->
        <div class="block">
          <h2><span class="mdi mdi-truck-download"></span> Возврат Опт</h2>
          <div class="desc">Приемка от оптовых и розничных покупателей</div>
          <div class="row">
            <div>
              <div class="icon-label"><span>🔘</span><label>Шины</label></div>
              <input type="number" id="optInTires" min="0" value="0">
            </div>
            <div>
              <div class="icon-label"><span>🛞</span><label>Диски</label></div>
              <input type="number" id="optInDiscs" min="0" value="0">
            </div>
          </div>
        </div>
        
        <!-- МП Приемка -->
        <div class="block mp">
          <h2><span class="mdi mdi-truck-download"></span> Возврат МП</h2>
          <div class="desc">Приемка возвратов с МП</div>
          <div class="row">
            <div>
              <div class="icon-label"><span>🔘</span><label>Шины</label></div>
              <input type="number" id="mpInTires" min="0" value="0">
            </div>
            <div>
              <div class="icon-label"><span>🛞</span><label>Диски</label></div>
              <input type="number" id="mpInDiscs" min="0" value="0">
            </div>
          </div>
        </div>
        
        <!-- ОПТ Размещение -->
        <div class="block">
          <h2><span class="mdi mdi-truck-upload"></span> Возврат Опт</h2>
          <div class="desc">Размещение возвратов от оптовых и розничных покупателей</div>
          <div class="row">
            <div>
              <div class="icon-label"><span>🔘</span><label>Шины</label></div>
              <input type="number" id="optOutTires" min="0" value="0">
            </div>
            <div>
              <div class="icon-label"><span>🛞</span><label>Диски</label></div>
              <input type="number" id="optOutDiscs" min="0" value="0">
            </div>
          </div>
        </div>
        
        <!-- МП Размещение -->
        <div class="block mp">
          <h2><span class="mdi mdi-truck-upload"></span> Возврат МП</h2>
          <div class="desc">Размещение возвратов с МП</div>
          <div class="row">
            <div>
              <div class="icon-label"><span>🔘</span><label>Шины</label></div>
              <input type="number" id="mpOutTires" min="0" value="0">
            </div>
            <div>
              <div class="icon-label"><span>🛞</span><label>Диски</label></div>
              <input type="number" id="mpOutDiscs" min="0" value="0">
            </div>
          </div>
        </div>
      </div>
      
      <button onclick="submitAll()">
        <span class="mdi mdi-send"></span> Отправить все
      </button>
    </div>
    
    <script>
      document.getElementById('reportDate').value = new Date().toISOString().split('T')[0];
      
      function submitAll() {
        var date = document.getElementById('reportDate').value;
        if (!date) { showMessage('Укажите дату.', 'error'); return; }
        
        var data = {
          date: date,
          optInTires: parseInt(document.getElementById('optInTires').value) || 0,
          optInDiscs: parseInt(document.getElementById('optInDiscs').value) || 0,
          mpInTires: parseInt(document.getElementById('mpInTires').value) || 0,
          mpInDiscs: parseInt(document.getElementById('mpInDiscs').value) || 0,
          optOutTires: parseInt(document.getElementById('optOutTires').value) || 0,
          optOutDiscs: parseInt(document.getElementById('optOutDiscs').value) || 0,
          mpOutTires: parseInt(document.getElementById('mpOutTires').value) || 0,
          mpOutDiscs: parseInt(document.getElementById('mpOutDiscs').value) || 0
        };
        
        var total = data.optInTires + data.optInDiscs + data.mpInTires + data.mpInDiscs +
                    data.optOutTires + data.optOutDiscs + data.mpOutTires + data.mpOutDiscs;
        if (total === 0) { showMessage('Укажите количество хотя бы в одном поле.', 'error'); return; }
        
        var btn = document.querySelector('button');
        btn.disabled = true;
        btn.innerHTML = '<span class="mdi mdi-loading mdi-spin"></span> Отправка...';
        
        google.script.run
          .withSuccessHandler(function(r) {
            btn.disabled = false;
            btn.innerHTML = '<span class="mdi mdi-send"></span> Отправить все';
            if (r.status === 'success') {
              showMessage('✓ ' + r.message, 'success');
              ['optInTires','optInDiscs','mpInTires','mpInDiscs','optOutTires','optOutDiscs','mpOutTires','mpOutDiscs']
                .forEach(function(id) { document.getElementById(id).value = '0'; });
            }
          })
          .withFailureHandler(function(e) {
            btn.disabled = false;
            btn.innerHTML = '<span class="mdi mdi-send"></span> Отправить все';
            showMessage('Ошибка: ' + e.message, 'error');
          })
          .submitReturns(data);
      }
      
      function showMessage(t, type) {
        var b = document.getElementById('messageBox');
        b.textContent = t; b.className = 'result-message ' + type;
        if (type === 'success') setTimeout(function() { b.className = 'result-message'; }, 4000);
      }
    </script>
  </body>
</html>
